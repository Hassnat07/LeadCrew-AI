# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is in .gitignore.

OPENAI_API_KEY=your_openai_api_key_here
SERPER_API_KEY=your_serper_api_key_here

# Optional — raises the PageSpeed API limit from 25/day to 25,000/day (free)
# Get one at: console.cloud.google.com → APIs → PageSpeed Insights API
PAGESPEED_API_KEY=your_google_pagespeed_api_key_here

GMAIL_ADDRESS=your_email@yourdomain.com
GMAIL_APP_PASSWORD=your_email_app_password_here

YOUR_NAME=Your Full Name
YOUR_COMPANY=Your Company Name
